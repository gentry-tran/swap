#!/usr/bin/env bash
# swap — Config-driven Claude Code account switcher
#
# Claude Code stores one OAuth credential at a time in the macOS login
# Keychain under the service name "Claude Code-credentials". That makes the
# CLI single-account: signing into a second subscription overwrites the first,
# forcing a full browser re-login every time you switch.
#
# swap backs up each account's Keychain credential to a local vault and
# restores it on demand, so switching between subscriptions is instant and
# never requires re-authenticating through the browser.
#
# Vault layout (~/.config/swap by default):
#   accounts.json        registry: { name -> { email, browser } }
#   <name>.keychain      saved Keychain credential blob (the OAuth token)
#   <name>.oauth.json    saved .claude.json `oauthAccount` block (the identity)
#   <name>.email         the account's email (display/metadata)
#   .active              name of the currently restored account
#
# SCOPE: manages ONLY the default Claude Code profile (Keychain service
# "Claude Code-credentials"). Concurrent profiles launched with a custom
# CLAUDE_CONFIG_DIR use a per-config Keychain service
# ("Claude Code-credentials-<hash>") and are NOT touched by this tool.
#
# Requires: macOS (security(1)), bash, python3.
set -euo pipefail

VAULT="${SWAP_VAULT:-${XDG_CONFIG_HOME:-$HOME/.config}/swap}"
CONFIG="$VAULT/accounts.json"
ACTIVE_FILE="$VAULT/.active"
KEYCHAIN_SERVICE="Claude Code-credentials"
# Claude Code stores its credential keyed by the macOS account name (your login
# user), NOT the email. The Keychain item MUST be written with this exact
# account attribute or `claude` won't find it and will demand a fresh login.
KEYCHAIN_ACCOUNT="${USER:-$(id -un)}"

# Claude Code records WHICH account is active in this JSON file's `oauthAccount`
# block (email, account/org UUIDs). The Keychain holds the token; this file holds
# the identity. A full switch must swap BOTH — restoring only the token leaves
# `claude` reporting the previous account ("auth didn't update").
CLAUDE_JSON="${SWAP_CLAUDE_JSON:-$HOME/.claude.json}"

mkdir -p "$VAULT"

# ── Config helpers ──────────────────────────────────────

load_config() {
  [ -f "$CONFIG" ] && cat "$CONFIG" || echo '{"accounts":{}}'
}

save_config() {
  local json="$1"
  echo "$json" > "$CONFIG"
  chmod 600 "$CONFIG"
}

get_account_field() {
  local name="$1" field="$2"
  load_config | NAME="$name" FIELD="$field" python3 -c "
import json, os, sys
d = json.load(sys.stdin)
acct = d.get('accounts', {}).get(os.environ['NAME'], {})
print(acct.get(os.environ['FIELD'], ''))
" 2>/dev/null
}

list_accounts() {
  load_config | VAULT="$VAULT" ACTIVE_FILE="$ACTIVE_FILE" python3 -c "
import json, os, sys
d = json.load(sys.stdin)
accounts = d.get('accounts', {})
if not accounts:
    print('No accounts configured. Use: swap add <name> --email <email>')
    sys.exit(0)
af = os.environ['ACTIVE_FILE']
vault = os.environ['VAULT']
active = open(af).read().strip() if os.path.exists(af) else ''
for name, info in sorted(accounts.items()):
    marker = ' <-' if name == active else ''
    browser = info.get('browser', 'default')
    has_creds = 'OK' if os.path.exists(f'{vault}/{name}.keychain') else '--'
    email = info.get('email', '')
    # When the account name IS the email, show it once; otherwise 'name (email)'.
    ident = email if name == email else f'{name} ({email})'
    print(f'  [{has_creds}] {ident:38s} browser={browser}{marker}')
" 2>/dev/null
}

# ── Commands ────────────────────────────────────────────

cmd_add() {
  local name="" email="" browser="default"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --email|-e) email="$2"; shift 2;;
      --browser|-b) browser="$2"; shift 2;;
      *) [ -z "$name" ] && name="$1" && shift || { echo "Unknown arg: $1" >&2; exit 1; };;
    esac
  done
  if [ -z "$name" ] || [ -z "$email" ]; then
    echo "Usage: swap add <name> --email <email> [--browser <browser>]"
    echo "  browser: Safari, Chrome, 'Brave Browser', Firefox, Arc, default"
    exit 1
  fi
  local config
  config=$(load_config)
  config=$(echo "$config" | NAME="$name" EMAIL="$email" BROWSER="$browser" python3 -c "
import json, os, sys
d = json.load(sys.stdin)
d.setdefault('accounts', {})[os.environ['NAME']] = {'email': os.environ['EMAIL'], 'browser': os.environ['BROWSER']}
print(json.dumps(d, indent=2))
")
  save_config "$config"
  echo "Added account '$name' ($email, browser=$browser)"
  echo "Now run: swap login $name"
}

cmd_remove() {
  local name="$1"
  local config
  config=$(load_config)
  config=$(echo "$config" | NAME="$name" python3 -c "
import json, os, sys
d = json.load(sys.stdin)
d.get('accounts', {}).pop(os.environ['NAME'], None)
print(json.dumps(d, indent=2))
")
  save_config "$config"
  rm -f "$VAULT/${name}.keychain" "$VAULT/${name}.email" "$VAULT/${name}.oauth.json"
  echo "Removed account '$name'"
}

cmd_login() {
  local name="$1"
  local email browser
  email=$(get_account_field "$name" "email")
  browser=$(get_account_field "$name" "browser")
  if [ -z "$email" ]; then
    echo "Account '$name' not found. Use: swap add $name --email <email>" >&2; exit 1
  fi
  echo "Logging in as $email..."
  run_claude_login "$email" "$browser"
  # Verify the browser session is ACTUALLY this account before saving. If you
  # signed into a different account (e.g. the browser was already logged in as
  # someone else), saving would write the wrong token+identity under this name.
  local got; got="$(current_auth_email)"
  if [ -z "$got" ]; then
    echo "Sign-in didn't complete — nothing saved for '$name'." >&2; exit 1
  fi
  if [ "$(printf '%s' "$got" | tr 'A-Z' 'a-z')" != "$(printf '%s' "$email" | tr 'A-Z' 'a-z')" ]; then
    echo "Refusing to save: you signed in as '$got', but '$name' expects '$email'." >&2
    echo "Sign out of '$got' in the browser, then run: swap login $name" >&2
    exit 1
  fi
  cmd_save "$name"
  printf "%s" "$name" > "$ACTIVE_FILE"
  echo "Logged in and saved as '$name' ($email)"
}

# Save the active account's `oauthAccount` identity block (from .claude.json).
save_oauth() {
  local name="$1"
  [ -f "$CLAUDE_JSON" ] || return 0
  CJ="$CLAUDE_JSON" OUT="$VAULT/${name}.oauth.json" python3 -c "
import json, os
try: d = json.load(open(os.environ['CJ']))
except Exception: raise SystemExit
oa = d.get('oauthAccount')
if oa is not None:
    json.dump(oa, open(os.environ['OUT'], 'w'))
" 2>/dev/null
  [ -f "$VAULT/${name}.oauth.json" ] && chmod 600 "$VAULT/${name}.oauth.json"
  return 0
}

# Restore an account's `oauthAccount` identity block into .claude.json so that
# `claude` reports/uses the matching account (the token alone is not enough).
restore_oauth() {
  local name="$1" f="$VAULT/${name}.oauth.json"
  [ -s "$f" ] || return 0
  [ -f "$CLAUDE_JSON" ] || return 0
  CJ="$CLAUDE_JSON" OA="$f" python3 -c "
import json, os
try:
    d = json.load(open(os.environ['CJ']))
    oa = json.load(open(os.environ['OA']))
except Exception: raise SystemExit
d['oauthAccount'] = oa
json.dump(d, open(os.environ['CJ'], 'w'))
" 2>/dev/null
  return 0
}

cmd_save() {
  local name="$1"
  local email
  email=$(get_account_field "$name" "email")
  if [ -z "$email" ]; then
    echo "Account '$name' not found." >&2; exit 1
  fi
  # Extract credentials from the Keychain. Claude keys the item by the macOS
  # account name; fall back to a service-only lookup just in case.
  local creds
  creds=$(security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" -w 2>/dev/null || echo "")
  if [ -z "$creds" ]; then
    creds=$(security find-generic-password -s "$KEYCHAIN_SERVICE" -w 2>/dev/null || echo "")
  fi
  if [ -n "$creds" ]; then
    echo "$creds" > "$VAULT/${name}.keychain"
    chmod 600 "$VAULT/${name}.keychain"
    echo "$email" > "$VAULT/${name}.email"
    save_oauth "$name"          # capture the matching identity block too
    echo "Saved credentials for '$name' ($email)"
  else
    echo "No credentials found in Keychain for $email. Login first: swap login $name" >&2
  fi
}

keychain_purge() {
  # Drop every Claude Code-credentials item so a stale one can't shadow the active account.
  while security delete-generic-password -s "$KEYCHAIN_SERVICE" >/dev/null 2>&1; do :; done
}

# Email recorded in the live ~/.claude.json oauthAccount block (NOT from the
# network). Identifies which account the live Keychain token currently belongs to.
live_oauth_email() {
  [ -f "$CLAUDE_JSON" ] || return 0
  CJ="$CLAUDE_JSON" python3 -c "
import json, os
try: d = json.load(open(os.environ['CJ']))
except Exception: raise SystemExit
print((d.get('oauthAccount') or {}).get('emailAddress', ''))
" 2>/dev/null
}

# Re-snapshot the CURRENTLY-active account before we switch away from it.
# Claude rotates the refresh token on every use (last-refresh-wins), so the
# vault copy goes stale the moment that account is used. Without this, switching
# away then back restores a rotated-out (dead) token → forced browser /login.
# Guard: only overwrite the outgoing account's files when the live identity block
# actually matches that account, so we never write account A's token into B's file.
sync_active_snapshot() {
  local target="$1"
  local active=""
  [ -f "$ACTIVE_FILE" ] && active=$(cat "$ACTIVE_FILE")
  [ -z "$active" ] && return 0
  [ "$active" = "$target" ] && return 0           # not switching away from anything
  local want live
  want=$(get_account_field "$active" "email")
  [ -z "$want" ] && return 0
  live=$(live_oauth_email)
  # Only re-save if the live token demonstrably belongs to the outgoing account.
  if [ -n "$live" ] && [ "$(printf '%s' "$live" | tr 'A-Z' 'a-z')" = "$(printf '%s' "$want" | tr 'A-Z' 'a-z')" ]; then
    local creds
    creds=$(security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" -w 2>/dev/null || security find-generic-password -s "$KEYCHAIN_SERVICE" -w 2>/dev/null || true)
    if [ -n "$creds" ]; then
      printf '%s' "$creds" > "$VAULT/${active}.keychain"
      chmod 600 "$VAULT/${active}.keychain"
      save_oauth "$active"
    fi
  fi
}

cmd_restore() {
  local name="$1"
  local email creds kc
  email=$(get_account_field "$name" "email")
  if [ -z "$email" ]; then
    echo "Account '$name' not found. Use: swap add $name --email <email>" >&2; exit 1
  fi
  sync_active_snapshot "$name"   # capture outgoing account's rotated token BEFORE switching
  kc="$VAULT/${name}.keychain"
  if [ ! -s "$kc" ]; then
    echo "No saved credentials for '$name'. Run: swap login $name" >&2; exit 1
  fi
  creds=$(cat "$kc")
  keychain_purge
  # Write the item under the macOS account name claude reads (NOT the email),
  # or claude won't find it and will force a fresh login. -U updates if present.
  security add-generic-password -U -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" -w "$creds"
  restore_oauth "$name"         # swap the identity block too, or claude shows the old account
  printf "%s" "$name" > "$ACTIVE_FILE"
  echo "Switched to '$name' ($email). Restart 'claude' — it'll be signed in automatically (no /login)."
}

cmd_use() {
  cmd_restore "$1"
}

account_names() {
  load_config | python3 -c "
import json, sys
for n in sorted(json.load(sys.stdin).get('accounts', {})):
    print(n)
" 2>/dev/null
}

set_account_browser() {
  local name="$1" browser="$2"
  local config
  config=$(load_config)
  config=$(echo "$config" | NAME="$name" BROWSER="$browser" python3 -c "
import json, os, sys
d = json.load(sys.stdin)
acct = d.setdefault('accounts', {}).get(os.environ['NAME'])
if acct is not None:
    acct['browser'] = os.environ['BROWSER']
print(json.dumps(d, indent=2))
")
  save_config "$config"
}

# Enumerate the browsers registered on THIS machine — no hardcoded app list.
# Asks LaunchServices (via lsregister -dump) which top-level applications claim
# the http+https URL schemes; that is exactly the set macOS would offer as a
# default web browser. Nested helper apps (browsers bundled inside other apps)
# and cached/throwaway copies are filtered out. Deterministic: sorted by name.
# SWAP_LSREGISTER overrides the lsregister path (used by the test suite).
detect_browsers() {
  local lsr="${SWAP_LSREGISTER:-/System/Library/Frameworks/CoreServices.framework/Versions/A/Frameworks/LaunchServices.framework/Versions/A/Support/lsregister}"
  [ -x "$lsr" ] || return 0
  "$lsr" -dump 2>/dev/null | python3 -c '
import sys, os, re
home = os.path.expanduser("~")
parents = {"/Applications", "/System/Applications",
           "/System/Volumes/Preboot/Cryptexes/App/System/Applications",
           home + "/Applications"}
def is_top_level_app(p):
    # A real installed app: <Applications-dir>/<Name>.app, not nested in another bundle.
    return p.endswith(".app") and p.count(".app") == 1 and os.path.dirname(p) in parents
seen = {}
for block in re.split(r"^-{80}$", sys.stdin.read(), flags=re.M):
    schemes = [l.strip() for l in block.splitlines() if l.strip().startswith("claimed schemes:")]
    if not schemes or "http:" not in schemes[0] or "https:" not in schemes[0]:
        continue
    m = re.search(r"^\s*path:\s+(/.*\.app)(?:\s+\(0x[0-9a-f]+\))?\s*$", block, re.M)
    if not m or not is_top_level_app(m.group(1)):
        continue
    seen.setdefault(os.path.basename(m.group(1))[:-4], m.group(1))
for name in sorted(seen):
    print(name)
'
}

# Email of the currently signed-in Claude account, per `claude auth status`.
# Empty if not signed in (token expired / no valid session).
current_auth_email() {
  claude auth status --json 2>/dev/null | python3 -c "
import sys, json
try: d = json.load(sys.stdin)
except Exception: d = {}
print(d.get('email', '') if d.get('loggedIn') else '')
" 2>/dev/null
}

# True if the cached credential blob carries a refresh token (so Claude can
# re-mint an access token on launch without a browser). Arg: keychain file.
blob_has_refresh() {
  python3 -c "
import sys, json
try: o = json.load(open('$1'))
except Exception: sys.exit(1)
o = o.get('claudeAiOauth', o)
sys.exit(0 if o.get('refreshToken') else 1)
" 2>/dev/null
}

# Run the Claude browser OAuth. Args: <email-or-empty> <browser-or-default>.
# An empty email defers to claude's own sign-in page (you pick the account).
run_claude_login() {
  local email="$1" browser="$2"
  keychain_purge
  if [ "$browser" != "default" ] && [ -n "$browser" ]; then
    local opener; opener=$(mktemp); chmod +x "$opener"
    printf '#!/bin/bash\nopen -a "%s" "$1"\n' "$browser" > "$opener"
    if [ -n "$email" ]; then BROWSER="$opener" claude auth login --email "$email"
    else BROWSER="$opener" claude auth login; fi
    rm -f "$opener"
  else
    if [ -n "$email" ]; then claude auth login --email "$email"
    else claude auth login; fi
  fi
}

# Interactive browser chooser. Arg: current browser. Menu -> stderr, choice -> stdout.
choose_browser() {
  local current="$1" b
  local -a browsers=()
  while IFS= read -r b; do browsers+=("$b"); done < <(detect_browsers)
  if [ ${#browsers[@]} -eq 0 ]; then printf '%s' "$current"; return; fi
  # If the current/saved browser isn't actually installed, Enter must fall back
  # to the system default — NEVER to a dead app that open(1) silently can't launch.
  local fallback="$current"
  if [ -n "$current" ] && [ "$current" != "default" ] && ! browser_installed "$current"; then
    fallback="default"
  fi
  { echo ""
    echo "Which browser for sign-in? (detected on this Mac)"
    local j; for j in "${!browsers[@]}"; do printf "  %d) %s\n" "$((j+1))" "${browsers[$j]}"; done
    if [ "$fallback" = "default" ]; then
      echo "  Enter = use the system default browser"
    else
      echo "  Enter = keep current ($fallback)"
    fi
  } >&2
  local bpick; read -r -p "Browser #: " bpick
  if [ -z "$bpick" ]; then printf '%s' "$fallback"
  elif [[ "$bpick" =~ ^[0-9]+$ ]] && [ "$bpick" -ge 1 ] && [ "$bpick" -le ${#browsers[@]} ]; then
    printf '%s' "${browsers[$((bpick-1))]}"
  else printf '%s' "$bpick"; fi
}

# True if a browser value is usable: "default" (system browser) or a detected app.
browser_installed() {
  local target="$1" b
  [ "$target" = "default" ] && return 0
  while IFS= read -r b; do [ "$b" = "$target" ] && return 0; done < <(detect_browsers)
  return 1
}

# Decide the browser for a sign-in. If the account already has a usable saved
# browser, use it silently. Only prompt when none is saved or it's not installed.
# Echoes the browser to stdout (any prompt goes to stderr).
ensure_browser() {
  local name="$1" br
  br=$(get_account_field "$name" "browser")
  if [ -n "$br" ] && browser_installed "$br"; then
    printf '%s' "$br"; return
  fi
  br="$(choose_browser "$br")"
  set_account_browser "$name" "$br"
  printf '%s' "$br"
}

# Interactive: pick an account, then switch to it (prompting for a browser only
# when a sign-in is actually needed and no usable browser is saved).
cmd_swap() {
  local -a names=()
  while IFS= read -r n; do names+=("$n"); done < <(account_names)

  local name browser
  if [ ${#names[@]} -eq 0 ]; then
    # No accounts yet: run Claude's own sign-in, then register whatever account
    # you logged into (named by its email). This is exactly `claude auth login`.
    echo "No accounts saved yet — signing in with Claude."
    browser="$(choose_browser default)"
    echo ""
    echo "Opening ${browser:-the default browser} to sign in..."
    run_claude_login "" "$browser"
    local email; email="$(current_auth_email)"
    if [ -z "$email" ]; then
      echo "Sign-in didn't complete — no account saved." >&2; exit 1
    fi
    cmd_add "$email" --email "$email" --browser "$browser" >/dev/null
    cmd_save "$email" >/dev/null
    printf "%s" "$email" > "$ACTIVE_FILE"
    echo "Signed in and saved as '$email'. Restart 'claude' — it'll be signed in automatically."
    return 0
  fi

  local active=""
  [ -f "$ACTIVE_FILE" ] && active=$(cat "$ACTIVE_FILE")

  echo "Choose an account to swap to:"
  local i
  for i in "${!names[@]}"; do
    local n="${names[$i]}"
    local email has marker ident
    email=$(get_account_field "$n" "email")
    # "saved" requires BOTH the token AND the identity block. A lone keychain
    # (e.g. a token copied in without a real login) is NOT a usable account.
    { [ -s "$VAULT/${n}.keychain" ] && [ -s "$VAULT/${n}.oauth.json" ]; } && has="saved" || has="needs login"
    [ "$n" = "$active" ] && marker=" (active)" || marker=""
    # Show the email once when the account name IS the email.
    [ "$n" = "$email" ] && ident="$email" || ident="$n ($email)"
    printf "  %d) %-38s [%s]%s\n" "$((i+1))" "$ident" "$has" "$marker"
  done

  local pick
  read -r -p "Account # (or name): " pick
  if [[ "$pick" =~ ^[0-9]+$ ]] && [ "$pick" -ge 1 ] && [ "$pick" -le ${#names[@]} ]; then
    name="${names[$((pick-1))]}"
  else
    name="$pick"
  fi
  if [ -z "$(get_account_field "$name" "email")" ]; then
    echo "No such account: $name" >&2; exit 1
  fi

  echo ""
  if [ -s "$VAULT/${name}.keychain" ] && [ -s "$VAULT/${name}.oauth.json" ]; then
    # A COMPLETE saved account (token + identity) exists: restore it, then VERIFY
    # the restored session actually belongs to THIS account before trusting it.
    # Without the match check, a missing/mismatched identity leaves claude on the
    # PREVIOUS account and current_auth_email reports that old email as "valid".
    cmd_restore "$name"
    local want who
    want=$(get_account_field "$name" "email")
    who="$(current_auth_email)"
    if [ -n "$who" ] && [ "$(printf '%s' "$who" | tr 'A-Z' 'a-z')" = "$(printf '%s' "$want" | tr 'A-Z' 'a-z')" ]; then
      echo "✓ Auth still valid ($who) — no browser sign-in needed. Restart 'claude'."
    elif [ -z "$who" ] && blob_has_refresh "$VAULT/${name}.keychain"; then
      # Access token expired but a refresh token is cached: claude re-mints on launch.
      echo "✓ Cached credentials present — Claude will refresh the token automatically on launch. No sign-in needed."
    else
      # who empty (expired + no refresh) OR who != this account (cached creds
      # don't actually belong to '$name'). Either way: do a real browser sign-in.
      if [ -n "$who" ] && [ "$who" != "$want" ]; then
        echo "Restored session is '$who', not '$want' — no valid saved auth for '$name'. Re-authenticating..."
      else
        echo "Cached auth for '$name' is expired — re-authenticating..."
      fi
      local browser; browser="$(ensure_browser "$name")"
      echo "Opening ${browser:-the default browser} to sign in..."
      cmd_login "$name"
    fi
  else
    # First time for this account (or cache cleared): seed it with one browser
    # OAuth. After this, future swaps are instant restores.
    local em browser; em=$(get_account_field "$name" "email")
    echo "No saved credentials for '$name' yet."
    browser="$(ensure_browser "$name")"
    echo "Opening ${browser:-the default browser} to sign in as ${em}..."
    cmd_login "$name"
  fi
}

cmd_which() {
  local active="none"
  [ -f "$ACTIVE_FILE" ] && active=$(cat "$ACTIVE_FILE")
  local email
  email=$(get_account_field "$active" "email")
  if [ -z "$active" ] || [ "$active" = "none" ]; then
    echo "none"
  elif [ -n "$email" ]; then
    # Lead with the email; only show the short name when it differs.
    if [ "$active" = "$email" ]; then echo "$email"; else echo "$email ($active)"; fi
  else
    echo "$active (unknown)"
  fi
}

usage() {
  echo "swap — Claude Code account switcher"
  echo ""
  echo "Run with no command to interactively pick an account and switch."
  echo ""
  echo "Commands:"
  echo "  (no args)                                      Interactive: pick account + browser, switch"
  echo "  add <name> --email <email> [--browser <app>]   Register an account"
  echo "  remove <name>                                   Remove an account"
  echo "  login <name>                                    OAuth login + save credentials"
  echo "  use <name>                                      Switch to saved credentials (non-interactive)"
  echo "  save <name>                                     Save current Keychain creds"
  echo "  list                                            List all accounts"
  echo "  which                                           Show active account"
  echo "  browsers                                        List browsers detected on this Mac"
  echo ""
  echo "Examples:"
  echo "  swap add work --email you@company.com --browser Chrome"
  echo "  swap add personal --email you@example.com --browser Safari"
  echo "  swap            # interactive picker"
  echo "  swap use personal"
}

# ── Main ────────────────────────────────────────────────

if [ $# -lt 1 ]; then
  cmd_swap
  exit 0
fi

case "$1" in
  add)     shift; cmd_add "$@";;
  remove)  cmd_remove "$2";;
  login)   cmd_login "$2";;
  save)    cmd_save "$2";;
  use)     cmd_use "$2";;
  swap)    cmd_swap;;
  list)    list_accounts;;
  which)   cmd_which;;
  browsers) detect_browsers;;
  help|--help|-h) usage;;
  *)
    echo "Unknown command '$1'. Run 'swap help' for usage." >&2; exit 1;;
esac
