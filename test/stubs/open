#!/usr/bin/env bash
# Test stub for macOS open(1). Models just what `swap` uses:
#   open -Ra "<App>"   -> exit 0 only for an allowlisted, installed-looking set
#   open -a "<App>" …  -> no-op success (login opener path)
# This makes browser detection deterministic under test.
if [ "${1:-}" = "-Ra" ]; then
  case "${2:-}" in
    "Safari"|"Google Chrome"|"Firefox") exit 0;;
    *) exit 1;;
  esac
fi
exit 0
